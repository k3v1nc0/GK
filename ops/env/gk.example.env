# GK Fase 2 safe env example.
# Copy values server-side only. Do not put real secrets in Git.
# Expected real env location: /etc/gk/gk.env or another Codex-managed outside-Git path.

NODE_ENV=production
APP_BASE_DIR=/var/www/gk
GK_ASSET_SOURCE_DIR=/var/www/gk/assets

# Placeholders only. Codex must create the real database/user/password outside Git.
DATABASE_URL=mysql://__DB_USER__:__DB_PASSWORD__@127.0.0.1:3306/__DB_NAME__
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_SECRET=__SET_OUTSIDE_GIT__

# Fase 4 initial editor admin seed inputs.
# Real values must be rendered server-side only and must not be committed.
GK_INITIAL_EDITOR_ADMIN_EMAIL=__SET_OUTSIDE_GIT__
GK_INITIAL_EDITOR_ADMIN_PASSWORD_HASH=__SET_OUTSIDE_GIT__
GK_INITIAL_EDITOR_ADMIN_PASSWORD_HASH_ALGORITHM=__SET_OUTSIDE_GIT__

# Kevin-confirmed public endpoints. These are public routing values, not secrets.
# Game endpoint: https://gk-k3v1nc0.duckdns.org/
# Editor endpoint: https://gk-k3v1nc0.duckdns.org/editor
GAME_DOMAIN=gk-k3v1nc0.duckdns.org
GAME_PUBLIC_PATH=/
EDITOR_DOMAIN=gk-k3v1nc0.duckdns.org
EDITOR_PUBLIC_PATH=/editor

# Optional strict checks for server-side validation scripts.
EXPECTED_GLB_COUNT=4
EXPECTED_UI_COUNT=0
EXPECTED_AUDIO_COUNT=0
EXPECT_NO_ASSET_SUBDIRS=1
FAIL_ON_ASSET_SPACES=0
