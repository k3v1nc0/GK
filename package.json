{
  "name": "gk-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "node --loader ./scripts/ts-test-loader.mjs --test tests/*.test.mjs",
    "lint": "node scripts/check-workspace-boundaries.mjs",
    "smoke:browser": "node tests/smoke/browser-smoke.mjs",
    "smoke:browser:editor": "node tests/smoke/browser-smoke.mjs --editor",
    "smoke:browser:game": "node tests/smoke/browser-smoke.mjs --game"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
